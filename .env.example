# Copy this file to .env and fill in real values before running.
# Never commit .env to git.
# Generate a SECRET_KEY with: python3 -c "import secrets; print(secrets.token_hex(32))"

# Flask
SECRET_KEY=generate-with-python-see-above
FLASK_APP=app.py
FLASK_ENV=production
FLASK_DEBUG=0
HOST=0.0.0.0
PORT=5000

# Database — host-side scripts (scrapers) use these values directly
# Docker Compose backend overrides DB_HOST=db and DB_PORT=5432 internally
DB_HOST=localhost
DB_PORT=5433
DB_NAME=price_scraper
DB_USER=postgres
DB_PASSWORD=your-strong-password-here

# Connection pool (scrapers)
DB_MIN_CONN=2
DB_MAX_CONN=10

# Enable DB writes in scrapers (1 = write to DB, 0 = JSON only)
USE_DATABASE=1

# Admin panel (HTTP Basic Auth)
ADMIN_USER=your-admin-username
ADMIN_PASSWORD=your-admin-password

# CORS — set to your public domain after Phase 3
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
